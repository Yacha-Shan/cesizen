{% extends 'base.html.twig' %}

{% block title %}Accueil - CesiZen{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/accueil.css') }}">
{% endblock %}

{% block body %}
    <div class="accueil-wrapper">
        <div class="accueil-header">
            <div class="accueil-logo">
                <img src="{{ asset('images/logo_cesizen.png') }}" alt="Logo CesiZen">
                <span><span class="cesi">CESI</span><span class="zen">ZEN</span></span>
                <p>TEST</p>
            </div>

            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_article_new') }}" class="btn-ajouter-article" title="Ajouter un article">+</a>
            {% endif %}
        </div>

        {% if articles is empty %}
            <p class="aucun-article">Aucun article disponible pour le moment.</p>
        {% else %}
            {% for article in articles %}
                <div class="article-card">
                    <div class="article-card-header">
                        <p class="article-titre">{{ article.title }}</p>
                        {% if is_granted('ROLE_ADMIN') %}
                            <div class="article-actions">
                                <a href="{{ path('app_article_edit', {id: article.id}) }}" title="Modifier">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M21.731 2.269a2.625 2.625 0 00-3.712 0l-1.157 1.157 3.712 3.712 1.157-1.157a2.625 2.625 0 000-3.712zM19.513 8.199l-3.712-3.712-8.4 8.4a5.25 5.25 0 00-1.32 2.214l-.8 2.685a.75.75 0 00.933.933l2.685-.8a5.25 5.25 0 002.214-1.32l8.4-8.4z"/>
                                        <path d="M5.25 5.25a3 3 0 00-3 3v10.5a3 3 0 003 3h10.5a3 3 0 003-3V13.5a.75.75 0 00-1.5 0v5.25a1.5 1.5 0 01-1.5 1.5H5.25a1.5 1.5 0 01-1.5-1.5V8.25a1.5 1.5 0 011.5-1.5h5.25a.75.75 0 000-1.5H5.25z"/>
                                    </svg>
                                </a>

                                <button
                                    type="button"
                                    class="btn-delete-open"
                                    data-delete-url="{{ path('app_article_delete', {'id': article.id}) }}"
                                    data-delete-token="{{ csrf_token('delete' ~ article.id) }}"
                                    data-delete-message="Supprimer cet article ?"
                                    title="Supprimer"
                                >
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                        <path fill-rule="evenodd" d="M16.5 4.478v.227a48.816 48.816 0 013.878.512.75.75 0 11-.256 1.478l-.209-.035-1.005 13.07a3 3 0 01-2.991 2.77H8.084a3 3 0 01-2.991-2.77L4.087 6.66l-.209.035a.75.75 0 01-.256-1.478A48.567 48.567 0 017.5 4.705v-.227c0-1.564 1.213-2.9 2.816-2.951a52.662 52.662 0 013.369 0c1.603.051 2.815 1.387 2.815 2.951zm-6.136-1.452a51.196 51.196 0 013.273 0C14.39 3.05 15 3.684 15 4.478v.113a49.488 49.488 0 00-6 0v-.113c0-.794.609-1.428 1.364-1.452zm-.355 5.945a.75.75 0 10-1.5.058l.347 9a.75.75 0 101.499-.058l-.346-9zm5.48.058a.75.75 0 10-1.498-.058l-.347 9a.75.75 0 001.5.058l.345-9z" clip-rule="evenodd"/>
                                    </svg>
                                </button>

                                <form id="delete-article-form" method="post" action="" style="display:none;">
                                    <input type="hidden" name="_token" value="">
                                </form>
                            </div>
                        {% endif %}
                    </div>

                    <p class="article-contenu">
                        {{ article.content|striptags|slice(0, 150) }}{% if article.content|striptags|length > 150 %}...{% endif %}
                    </p>

                    <div class="article-footer">
                        <div class="article-dates">
                            <span>{{ article.createdAt|date('d-m-Y') }}</span>
                            {% if article.updatedAt and article.updatedAt != article.createdAt %}
                                <span class="article-date-modif">- {{ article.updatedAt|date('d-m-Y') }}</span>
                            {% endif %}
                        </div>

                        <a href="{{ path('app_article_show', {id: article.id}) }}" class="lien-voir-plus">Voir plus</a>
                    </div>
                </div>
            {% endfor %}
        {% endif %}

        <div class="delete-modal" id="deleteModal" aria-hidden="true">
            <div class="delete-modal__overlay" data-close-delete-modal></div>
            <div class="delete-modal__content" role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle">
                <h2 class="delete-modal__title" id="deleteModalTitle">Confirmation de suppression</h2>
                <p class="delete-modal__text" id="deleteModalText">Voulez-vous vraiment supprimer cet élément ?</p>

                <div class="delete-modal__actions">
                    <button type="button" class="delete-modal__cancel" data-close-delete-modal>Annuler</button>
                    <button type="button" class="delete-modal__confirm" id="deleteModalConfirm">Supprimer</button>
                </div>
            </div>
        </div>

    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const modal = document.getElementById('deleteModal');
            const modalText = document.getElementById('deleteModalText');
            const confirmBtn = document.getElementById('deleteModalConfirm');
            const deleteForm = document.getElementById('delete-article-form');

            if (!modal || !modalText || !confirmBtn || !deleteForm) {
                return;
            }

            let currentAction = '';
            let currentToken = '';

            document.querySelectorAll('.btn-delete-open').forEach(button => {
                button.addEventListener('click', () => {
                    currentAction = button.dataset.deleteUrl || '';
                    currentToken = button.dataset.deleteToken || '';
                    modalText.textContent = button.dataset.deleteMessage || 'Voulez-vous vraiment supprimer cet élément ?';
                    modal.classList.add('is-visible');
                    modal.setAttribute('aria-hidden', 'false');
                });
            });

            document.querySelectorAll('[data-close-delete-modal]').forEach(element => {
                element.addEventListener('click', () => {
                    modal.classList.remove('is-visible');
                    modal.setAttribute('aria-hidden', 'true');
                });
            });

            confirmBtn.addEventListener('click', () => {
                deleteForm.action = currentAction;
                deleteForm.querySelector('input[name="_token"]').value = currentToken;
                deleteForm.submit();
            });

            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') {
                    modal.classList.remove('is-visible');
                    modal.setAttribute('aria-hidden', 'true');
                }
            });
        });
    </script>
{% endblock %}
