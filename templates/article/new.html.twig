{% extends 'base.html.twig' %}

{% block title %}Nouvel article{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/article/new_article.css') }}">
{% endblock %}

{% block body %}
    <div class="new-page">

        <div class="brand">
            <img src="{{ asset('images/logo_cesizen.png') }}" alt="Logo Cesizen" class="brand-logo">
            <span class="brand-name">
                <span class="brand-cesi">CESI</span><span class="brand-zen">ZEN</span>
            </span>
        </div>

        <div class="new-card">

            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            <div class="new-field">
                <label class="new-label">Donner un titre à cet article :</label>
                {{ form_widget(form.title, {'attr': {'class': 'new-input', 'placeholder': "Titre de l'article"}}) }}
                {{ form_errors(form.title) }}
            </div>

            <div class="new-field">
                <label class="new-label">Entrez le contenu de votre article :</label>
                {{ form_widget(form.content, {'attr': {'class': 'new-textarea'}}) }}
                {{ form_errors(form.content) }}
            </div>

            <div class="new-actions">
                <a href="{{ path('app_info') }}" class="btn-retour">Retour</a>
                <button type="submit" class="btn-enregistrer">Enregistrer</button>
            </div>

            {{ form_end(form) }}

        </div>

    </div>

    <script src="https://cdn.ckeditor.com/ckeditor5/41.0.0/classic/ckeditor.js"></script>
    <script>
        ClassicEditor
            .create(document.querySelector('.new-textarea'), {
                toolbar: ['heading', '|', 'bold', 'italic', 'underline', 'strikethrough', '|', 'alignment', '|', 'bulletedList', 'numberedList', '|', 'undo', 'redo'],
                heading: {
                    options: [
                        { model: 'paragraph', title: 'Paragraph', class: 'ck-heading_paragraph' },
                        { model: 'heading1', view: 'h1', title: 'Heading 1', class: 'ck-heading_heading1' },
                        { model: 'heading2', view: 'h2', title: 'Heading 2', class: 'ck-heading_heading2' },
                    ]
                }
            })
            .catch(error => console.error(error));
    </script>
{% endblock %}
