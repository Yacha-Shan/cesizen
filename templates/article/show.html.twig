{% extends 'base.html.twig' %}

{% block title %}Article{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/show_article.css') }}">
{% endblock %}

{% block body %}
    <div class="show-page">

        <div class="brand">
            <img src="{{ asset('images/logo_cesizen.png') }}" alt="Logo Cesizen" class="brand-logo">
            <span class="brand-name">
                <span class="brand-cesi">CESI</span><span class="brand-zen">ZEN</span>
            </span>
        </div>

        <div class="show-card">

            <div class="show-field">
                <span class="show-field-label">Titre de l'article :</span>
                <h1 class="show-title">{{ article.title }}</h1>
                <hr class="show-divider">
            </div>

            <div class="show-field">
                <span class="show-field-label">Article :</span>
                <div class="show-content-area">{{ article.content|raw }}</div>
            </div>

            <div class="show-actions">
                <a href="{{ path('app_info') }}" class="btn-retour">Retour</a>

                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_article_edit', {id: article.id}) }}" class="btn-modifier">Modifier</a>

                    <form method="post" action="{{ path('app_article_delete', {'id': article.id}) }}"
                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet article ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ article.id) }}">
                        <button type="submit" class="btn-supprimer">Supprimer</button>
                    </form>
                {% endif %}
            </div>

        </div>
    </div>
{% endblock %}
