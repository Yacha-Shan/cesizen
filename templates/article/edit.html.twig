{% extends 'base.html.twig' %}

{% block title %}Modifier l'article{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/article/edit_article.css') }}">
{% endblock %}

{% block body %}
    <div class="edit-page">

        <div class="brand">
            <img src="{{ asset('images/logo_cesizen.png') }}" alt="Logo Cesizen" class="brand-logo">
            <span class="brand-name">
                <span class="brand-cesi">CESI</span><span class="brand-zen">ZEN</span>
            </span>
        </div>

        <div class="edit-card">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            <div class="edit-field">
                <label class="edit-label">Donner un titre à cet article :</label>
                {{ form_widget(form.title, {'attr': {'class': 'edit-input', 'placeholder': "Titre de l'article"}}) }}
                {{ form_errors(form.title) }}
            </div>

            <div class="edit-field">
                <label class="edit-label">Entrez le contenu de votre article :</label>

                <div id="editor-container" class="editor-wrapper editor-loading">
                    {{ form_widget(form.content, {'attr': {'class': 'edit-textarea'}}) }}
                </div>

                {{ form_errors(form.content) }}
            </div>

            <div class="edit-actions">
                <a href="{{ path('app_info') }}" class="btn-retour">Retour</a>
                <button type="submit" class="btn-enregistrer">Enregistrer</button>
            </div>

            {{ form_end(form) }}
        </div>

    </div>

    <script src="https://cdn.ckeditor.com/ckeditor5/41.0.0/classic/ckeditor.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const textarea = document.getElementById('{{ form.content.vars.id }}');
            const wrapper = document.getElementById('editor-container');

            if (!textarea || !wrapper) {
                console.error('Champ contenu introuvable');
                return;
            }

            ClassicEditor
                .create(textarea, {
                    toolbar: ['heading', '|', 'bold', 'italic', 'underline', 'strikethrough', '|', 'alignment', '|', 'bulletedList', 'numberedList', '|', 'undo', 'redo'],
                    heading: {
                        options: [
                            { model: 'paragraph', title: 'Paragraph', class: 'ck-heading_paragraph' },
                            { model: 'heading1', view: 'h1', title: 'Heading 1', class: 'ck-heading_heading1' },
                            { model: 'heading2', view: 'h2', title: 'Heading 2', class: 'ck-heading_heading2' }
                        ]
                    }
                })
                .then(() => {
                    wrapper.classList.remove('editor-loading');
                })
                .catch(error => {
                    console.error('Erreur CKEditor edit:', error);
                    wrapper.classList.remove('editor-loading');
                });
        });
    </script>
{% endblock %}
